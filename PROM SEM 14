# Función para calcular el promedio
def calcular_promedio(n1, n2, n3):
    promedio = (n1 + n2 + n3) / 3
    return promedio

# Función para validar números entre 1 y 10
def pedir_nota(mensaje):
    while True:
        try:
            nota = float(input(mensaje))
            if 1 <= nota <= 10:
                return nota
            else:
                print("❌ Error: La nota debe estar entre 1 y 10.")
        except ValueError:
            print("❌ Error: Solo puede ingresar números.")

# Programa principal
print("------ PROMEDIO DE CALIFICACIONES ------")

nota1 = pedir_nota("Ingrese la primera nota: ")
nota2 = pedir_nota("Ingrese la segunda nota: ")
nota3 = pedir_nota("Ingrese la tercera nota: ")

# Llamada a la función
resultado = calcular_promedio(nota1, nota2, nota3)

# Mostrar resultado
print("El promedio es:", round(resultado, 2))
